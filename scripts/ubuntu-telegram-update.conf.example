# Sao chép file này và điền giá trị thật (sau `sudo bash install.sh`, mẫu nằm ở
# /usr/local/share/linux-telegram-monitor/ubuntu-telegram-update.conf.example):
#   sudo cp /usr/local/share/linux-telegram-monitor/ubuntu-telegram-update.conf.example /etc/ubuntu-telegram-update.conf
#   sudo chmod 600 /etc/ubuntu-telegram-update.conf
#   sudo nano /etc/ubuntu-telegram-update.conf
#
# Lấy BOT_TOKEN: tạo bot qua @BotFather trên Telegram, lưu token.
# Lấy CHAT_ID: gửi tin nhắn cho bot, mở:
#   https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
#   tìm "chat":{"id": ...}

TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# Tùy chọn (1 = bật):
# SEND_LOG_AS_DOCUMENT=1          # gửi kèm file log
# REBOOT_IF_REQUIRED=0            # KHÔNG tự reboot mặc định (chỉ báo trong tin nhắn)
# RUN_FWUPD=1                     # 1 = chạy fwupdmgr refresh + update nếu có lệnh; 0 = bỏ qua
