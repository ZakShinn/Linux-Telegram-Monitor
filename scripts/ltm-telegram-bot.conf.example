# Bot lenh Telegram — chi Chat ID khop moi dieu khien duoc
# Co the chi nguon token tu file bao cao:
#   source /etc/server-telegram-report.conf

TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"
# Mot hoac nhieu chat (phay): "123456789,-1001234567890"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# Chat duoc phep lenh nguy hiem (/reboot_now, /service restart, ...). De trong = chat dau tien.
# TELEGRAM_ADMIN_CHAT_ID=""

# Cho phep lenh tu xa (1=bat)
ALLOW_REMOTE_REPORT=1
ALLOW_REMOTE_UPDATE=0
ALLOW_REMOTE_ACTION=0

# Xac nhan hanh dong: /reboot_now -> bot tra token -> /confirm <token>
CONFIRM_TTL_SEC=90

# Duong dan script (sau install.sh)
PATH_REPORT="/usr/local/bin/server-telegram-report"
PATH_UPDATE="/usr/local/bin/server-telegram-update"
PATH_SCHEDULE="/usr/local/bin/ltm-schedule"

# Whitelist (copy mau tu /usr/local/share/linux-telegram-monitor/):
#   /etc/ltm-allowed-services.conf   — systemctl restart <unit>
#   /etc/ltm-allowed-docker.conf     — docker restart <name>
#   /etc/ltm-allow-commands.conf     — /exec <ten> -> /etc/ltm/exec/<ten>.sh

# Neu bot chay khong phai root: de trong hoac vi du SUDO_CMD="sudo -n"
SUDO_CMD=""

POLL_TIMEOUT=25
REMOTE_CMD_TIMEOUT=35
